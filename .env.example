# ============================================================================
# DjangoBlog — Environment Variables Reference
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control.
# ============================================================================

# ----------------------------------------------------------------------------
# Core Django Settings
# ----------------------------------------------------------------------------

# REQUIRED — Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# The app will refuse to start if this is not set.
DJANGO_SECRET_KEY=change-this-to-a-long-random-string

# Set to true in development, false in production (defaults to false if missing)
DJANGO_DEBUG=true

# Comma-separated list of allowed hostnames
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Comma-separated trusted origins for CSRF (include protocol + domain)
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000

# IANA timezone string (e.g. UTC, America/New_York, Europe/London)
DJANGO_TIME_ZONE=UTC

# Enable HTTPS redirect. Always false in local dev.
DJANGO_SECURE_SSL_REDIRECT=false

# Set to true in production when serving over HTTPS
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false

# Session engine: db (default), cache (production recommended with Redis)
DJANGO_SESSION_ENGINE=django.contrib.sessions.backends.db
DJANGO_SESSION_COOKIE_NAME=djangoblog_sessionid
DJANGO_SESSION_COOKIE_SAMESITE=lax

# Session lifetime in seconds (default: 14 days)
DJANGO_SESSION_COOKIE_AGE=1209600
DJANGO_SESSION_EXPIRE_AT_BROWSER_CLOSE=false
DJANGO_SESSION_SAVE_EVERY_REQUEST=false
DJANGO_SESSION_MARKER_PREFIX=djangoblog

# HSTS — 0 for dev, 31536000 (1 year) for production
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
DJANGO_SECURE_HSTS_PRELOAD=false

ENABLE_STAFF_ADMINBAR=true
ENABLE_ADMIN_CONTROL=true

# ----------------------------------------------------------------------------
# Database — PostgreSQL (REQUIRED, all four raise ValueError if missing)
# ----------------------------------------------------------------------------

POSTGRES_DB=djangoblog
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
# Persistent connection lifetime in seconds
POSTGRES_CONN_MAX_AGE=60

# ----------------------------------------------------------------------------
# Cache & Celery — Redis (required for SEO engine + async Celery tasks)
# ----------------------------------------------------------------------------

# Redis URL for django-redis CACHES backend (production)
REDIS_URL=redis://127.0.0.1:6379/1
REDIS_CACHE_URL=redis://127.0.0.1:6379/1

# Celery broker and result backend
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# ----------------------------------------------------------------------------
# Email
# ----------------------------------------------------------------------------

# Use console backend for dev (prints emails to stdout instead of sending)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
# For Gmail: use an App Password, not your account password
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ----------------------------------------------------------------------------
# SEO
# ----------------------------------------------------------------------------

# Full public URL of the site (used in sitemap + schema.org markup)
SEO_SITE_URL=http://localhost:8000
SEO_SITEMAP_ENABLED=True
SEO_XML_SITEMAP_ENABLED=True
SEO_ROBOTS_TXT_ENABLED=True

# ----------------------------------------------------------------------------
# AWS S3 — Optional media storage (leave USE_S3=False for local dev)
# ----------------------------------------------------------------------------

USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION_NAME=us-east-1
AWS_STORAGE_BUCKET_NAME=
AWS_S3_CUSTOM_DOMAIN=

# ----------------------------------------------------------------------------
# Site Branding
# ----------------------------------------------------------------------------

SITE_NAME=Django Blog
SITE_DESCRIPTION=A powerful Django blog platform
ORGANIZATION_NAME=Your Organization
ORGANIZATION_URL=http://localhost:8000
TWITTER_HANDLE=@yourhandle

# SEO keyword defaults
SEO_DEFAULT_KEYWORDS=django,python,web development,technology
SEO_AUTHOR=Your Name

# ----------------------------------------------------------------------------
# Error Tracking — Sentry (optional)
# ----------------------------------------------------------------------------

SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ----------------------------------------------------------------------------
# Development conveniences (never set in production)
# ----------------------------------------------------------------------------

DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=changeme


# Database Configuration (PostgreSQL recommended)
POSTGRES_DB=djangoblog
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Redis Configuration (for caching and Celery)
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_CACHE_URL=redis://127.0.0.1:6379/1
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# AWS S3 Configuration (optional, for media storage)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION_NAME=us-east-1
AWS_STORAGE_BUCKET_NAME=
AWS_S3_CUSTOM_DOMAIN=

# SEO Settings
SEO_SITE_URL=http://localhost:8000
SEO_SITEMAP_ENABLED=True
SEO_XML_SITEMAP_ENABLED=True
SEO_ROBOTS_TXT_ENABLED=True

# Sentry Error Tracking (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Site Branding
SITE_NAME=Django Blog
SITE_DESCRIPTION=A powerful Django blog platform
ORGANIZATION_NAME=Your Organization
ORGANIZATION_URL=http://localhost:8000
TWITTER_HANDLE=@yourhandle

# SEO Keywords
SEO_DEFAULT_KEYWORDS=django,python,web development,technology
SEO_AUTHOR=Your Name

# Features Flags  
ENABLE_COMMENTS=True
ENABLE_NEWSLETTER=True
ENABLE_SOCIAL_SHARING=True
ENABLE_ANALYTICS=True
ENABLE_SEO_AUDIT=True
ENABLE_AUTO_TAGGING=True
ENABLE_INTERNAL_LINKING=True

# Pagination
POSTS_PER_PAGE=12
COMMENTS_PER_PAGE=20

# Performance
CACHE_TIMEOUT=3600
DATABASE_CONN_POOL_SIZE=20

# Logging Level
LOG_LEVEL=INFO

# Development only
DEVELOPMENT_TOOLS_ENABLED=True
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=changeme
